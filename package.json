{
  "name": "@halos-org/skip",
  "version": "4.8.0",
  "main": "plugin/index.js",
  "publishConfig": {
    "access": "public"
  },
  "description": "An advanced and versatile marine instrumentation package to display Signal K data.",
  "license": "MIT",
  "author": {
    "name": "Matti Airas",
    "email": "matti.airas@hatlabs.fi"
  },
  "contributors": [
    {
      "name": "David Godin",
      "email": "godind@hotmail.com"
    },
    {
      "name": "Thomas St.Pierre",
      "email": "thomas@samoht.ca"
    },
    {
      "name": "Matti Airas",
      "email": "matti.airas@hatlabs.fi"
    }
  ],
  "homepage": "https://github.com/halos-org/skip",
  "bugs": "https://github.com/halos-org/skip/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/halos-org/skip.git"
  },
  "keywords": [
    "signalk-webapp",
    "signalk-node-server-plugin",
    "signalk-category-instruments",
    "signalk-category-notifications",
    "signalk-category-ais",
    "signal k",
    "signalk",
    "instruments",
    "dashboard",
    "marine",
    "nmea"
  ],
  "signalk": {
    "appIcon": "assets/icon-72x72.png",
    "displayName": "Skip"
  },
  "signalk-plugin-enabled-by-default": true,
  "files": [
    "public/**",
    "plugin/**",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTORS.md",
    "package.json"
  ],
  "scripts": {
    "test": "ng test --watch=false",
    "test:interactive": "ng test",
    "test:headless": "CI=1 ng test --watch=false",
    "test:mcp-schema": "vitest run --config tools/gen-mcp-schema/vitest.config.ts",
    "test:plugin": "tsc --noEmit -p plugin/tsconfig.json && vitest run --config plugin/vitest.config.ts",
    "gen:mcp-schema": "UPDATE_SCHEMA=1 npm run test:mcp-schema",
    "lint": "ng lint",
    "snc": "tsc -p tsconfig.strict.json",
    "betterer": "betterer --tsconfig tsconfig.betterer.json",
    "betterer:ci": "betterer ci --tsconfig tsconfig.betterer.json",
    "ci": "npm run lint && npm run betterer:ci && npm run test:headless && npm run test:plugin",
    "prepublishOnly": "npm run build:prod",
    "dev": "ng serve --configuration=dev --serve-path=/@halos-org/skip/",
    "build:dev": "ng build --configuration=dev",
    "build:prod": "ng build --configuration=production",
    "generate:widget": "npx schematics ./tools/schematics/collection.json:create-host2-widget --dry-run=false"
  },
  "schematics": "tools/schematics/collection.json",
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.6",
    "@angular-devkit/schematics-cli": "^20.1.6",
    "@angular/animations": "21.2.7",
    "@angular/build": "^21.2.6",
    "@angular/cdk": "21.2.5",
    "@angular/cli": "^21.2.6",
    "@angular/common": "21.2.7",
    "@angular/compiler": "21.2.7",
    "@angular/compiler-cli": "21.2.7",
    "@angular/core": "21.2.7",
    "@angular/forms": "21.2.7",
    "@angular/language-service": "21.2.7",
    "@angular/material": "21.2.5",
    "@angular/platform-browser": "21.2.7",
    "@angular/platform-browser-dynamic": "21.2.7",
    "@angular/router": "21.2.7",
    "@aziham/chartjs-plugin-streaming": "^3.5.1",
    "@betterer/cli": "^5.4.0",
    "@betterer/typescript": "^5.4.0",
    "@godind/ng-canvas-gauges": "^6.2.1",
    "@types/canvas-gauges": "^2.1.8",
    "@types/d3": "^7.4.3",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/js-quantities": "^1.6.6",
    "@types/lodash-es": "^4.17.9",
    "@types/node": "^24.1.0",
    "@types/piexifjs": "^1.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@zakj/no-sleep": "^0.13.5",
    "angular-eslint": "21.3.1",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-annotation": "^3.0.1",
    "clipboard": "^2.0.11",
    "compare-versions": "^6.1.1",
    "core-js": "^3.13.1",
    "d3": "^7.9.0",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "date-fns": "^2.30.0",
    "eslint": "^9.29.0",
    "globals": "^14.0.0",
    "gridstack": "^12.3.3",
    "js-quantities": "^1.8.0",
    "jsdom": "^26.1.0",
    "lodash-es": "^4.17.23",
    "ng-packagr": "^21.0.1",
    "ngx-markdown": "^21.0.1",
    "prismjs": "^1.30.0",
    "pwa-asset-generator": "^8.1.1",
    "rxjs": "^7.8.2",
    "sass": "^1.49.9",
    "screenfull": "^6.0.2",
    "sk-ais-status-plugin": "^1.0.0",
    "steelseries": "^2.0.9",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@signalk/server-api": "^2.22.0",
    "hls.js": "^1.6.16",
    "piexifjs": "^1.0.6"
  }
}
